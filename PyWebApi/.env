# -------- 基础配置 --------

APP_NAME=webapi
APP_PORT=80
APP_HOST=0.0.0.0
APP_DEBUG=true

# -------- 数据库配置 --------

# 数据库连接
DB_DSN=mysql+pymysql://root:123456@127.0.0.1:3306/webapi?charset=utf8mb4
# 使用打印SQL日志信息
DB_ECHO_SQL=True
# 连接池中的初始连接数，默认为 5
DB_POOL_SIZE=5
# 连接池中允许的最大超出连接数，默认为 10
DB_MAX_OVERFLOW=10

# -------- jwt配置 --------

# 秘钥
JWT_SECRET=6Kbj0VFeXYMp60lEyiFoVq4UzqX8Z0GSSfnvTh2VuAQn0oHgQNYexU6yYVTk4xf9
